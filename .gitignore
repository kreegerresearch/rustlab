# Generated files
/target/

# Cargo lock (keep for binaries, optional for libraries)
# Cargo.lock

# Editor and OS files
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# AI tool local settings
.claude/

# Project prompts (internal)
prompts/

# Local issue tracking
dev/issues/

# Environment files
.env

# Rust documentation
/doc/
*.svg
*.npz
*.npy

# Generated example outputs (scripts now live under examples/<toolbox>/,
# so the patterns need ** to match. The tracked TOML fixtures
# examples/language/toml_config.toml and examples/language/toml_filter_chain.toml
# stay because they don't match `toml_results.toml`.)
examples/**/*.csv
examples/**/*.html
**/toml_results.toml
*.html

# Notebook rendered output — sources live at examples/notebooks/*.md.
# `make notebooks` writes everything into gallery/:
#   gallery/<name>.md           committed → GitHub-browseable Markdown
#   gallery/plots/<name>/*.svg  committed → referenced by .md inline
#   gallery/plots/<name>/*.gif  committed → animated GIFs from saveanim()
#   gallery/<name>.html         ignored   → bulky Plotly bundles, local view
#   gallery/index.html          ignored   → generated index for the HTML build
# The carve-outs below override the global *.html rule for the gallery's
# committed assets. SVG and GIF aren't globally gitignored, but listing
# them here keeps the policy explicit.
gallery/*.html
gallery/*.gif
!gallery/
!gallery/**/*.svg

# Test fixtures: the deliberately-broken inputs for
# `rustlab-notebook validate`'s wrapper self-tests must be committed
# even though they match the global *.html ignore.
!crates/rustlab-notebook/tests/fixtures/**
!gallery/plots/**/*.gif

# Time-frequency notebook's CWT scalogram outputs render as ~1.28M SVG
# <rect> elements each (64 scales × 20000 samples), producing ~105MB
# files that exceed GitHub's 100MB push limit. Pending a renderer fix
# (PNG fallback or downsampling for dense heatmaps), exclude them so
# the rest of the notebook's plots can still be committed.
gallery/plots/time_frequency/plot-6-*.svg
gallery/plots/time_frequency/plot-7-*.svg
