# Generated files
/target/

# Cargo lock (keep for binaries, optional for libraries)
# Cargo.lock

# Editor and OS files
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# AI tool local settings
.claude/

# Project prompts (internal)
prompts/

# Local issue tracking
dev/issues/

# Environment files
.env

# Rust documentation
/doc/
*.svg
*.npz
*.npy

# Generated example outputs
examples/*.csv
examples/*.html
examples/*.toml
*.html

# Notebook rendered output — sources live at examples/notebooks/*.md.
# `make notebooks` regenerates two trees:
#   site/md/   committed → GitHub renders these inline with SVG plots
#   site/html/ ignored   → bulky Plotly bundles, regen locally to browse
# The carve-out below overrides the global *.svg rule for notebook plots.
examples/notebooks/site/html/
!examples/notebooks/site/md/plots/
!examples/notebooks/site/md/plots/**/*.svg
